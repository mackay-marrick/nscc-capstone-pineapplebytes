# =============================================================================
# PineappleBytes Middleware Environment Configuration
# =============================================================================
#
# Copy this file to .env and fill in the values:
#   cp .env.example .env
#
# For school/restricted networks, see network-troubleshooting.md for setup.
# For SSH tunnel setup, see the documentation below.
# =============================================================================

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
# 
# The system supports TWO connection modes:
#
# Mode 1: SSH Tunnel (Recommended for restricted networks)
# --------------------------------------------------------
# Set up an SSH tunnel first by running: start_tunnel.bat (Windows) or the
# equivalent command on Linux/Mac. This forwards local port 1433 to the RDS
# instance via the bastion host.
#
# Then configure:
DB_HOST=127.0.0.1
DB_PORT=1433
DB_USER=admin
DB_PASS=your_password_here
DB_NAME=PineappleBytes
#
# Mode 2: Direct RDS Connection (for unrestricted networks)
# --------------------------------------------------------
# Connect directly to the AWS RDS instance:
DB_SERVER=pineapplebytes-db.cyfqs2yieuln.us-east-1.rds.amazonaws.com\SQLEXPRESS,1433
DB_DATABASE=PineappleBytes
DB_USERNAME=admin
DB_PASSWORD=your_password_here
#
# Note: If both sets of variables are present, SSH tunnel variables take precedence.

# -----------------------------------------------------------------------------
# OpenRouter AI API
# -----------------------------------------------------------------------------
# Get your API key from: https://openrouter.ai/settings/integrations
# The default free tier has rate limits. Consider using your own key for production.
OPENROUTER_API_KEY=your_openrouter_api_key_here

# -----------------------------------------------------------------------------
# Offline/Cache Mode Configuration
# -----------------------------------------------------------------------------
# OFFLINE_MODE: When true, the system will attempt to use cached data if
#   network connectivity fails. Default is "true" for compatibility with
#   restricted networks.
#   Options: true | false
OFFLINE_MODE=true

# CACHE_ONLY_MODE: When true, the system will ONLY use cached data and will
#   NOT make any live API calls to OpenRouter (or database if cache is complete).
#   This is useful for working entirely offline without consuming tokens.
#   PREREQUISITE: You must run `python precache_all.py` first to populate cache.
#   Options: true | false
CACHE_ONLY_MODE=false

# -----------------------------------------------------------------------------
# AWS Infrastructure Info (For Reference/Scripts)
# -----------------------------------------------------------------------------
# These variables are used by the SSH tunnel script and deployment scripts.
# You typically don't need to set these manually if using the tunnel script.
BASTION_IP=44.201.167.193
RDS_ENDPOINT=pb-dev-db.cyfqs2yieuln.us-east-1.rds.amazonaws.com
KEY_PATH=C:\Users\marym\.ssh\pb-dev-key.pem

# -----------------------------------------------------------------------------
# Advanced Configuration (usually not needed)
# -----------------------------------------------------------------------------
# Cache directory (default: cache)
# CACHE_DIR=cache

# Database connection timeout in seconds (default: 30)
# DB_TIMEOUT=30

# API request timeout in seconds (default: 60)
# API_TIMEOUT=60

# Log level (default: INFO)
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
# LOG_LEVEL=INFO